<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- صلاحيات الشبكة -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- صلاحيات التخزين لرفع الملفات (للأجهزة القديمة فقط) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="35">

        <!--
            SplashActivity — نقطة الدخول الرئيسية (LAUNCHER).
            - تُهيئ AppConfig وتبدأ المزامنة في الخلفية.
            - theme مخصص (Theme.SchoolApp.Splash) لتلبية متطلبات AndroidX SplashScreen API.
            - تنتقل فوراً إلى MainActivity دون تأخير اصطناعي.
        -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SchoolApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            MainActivity — يستضيف الواجهة العامة للمدرسة (الموقع الرسمي).
            ✅ تم التصحيح: يعرض HOME_URL (AppConfig.HOME_URL) وليس CMS_URL.
            - المحتوى: الأخبار، الصور، الفيديوهات، الإحصائيات، أزرار المنصات.
            - configChanges يمنع إعادة تشغيل WebView عند تدوير الشاشة أو إظهار لوحة المفاتيح.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!--
            TeacherActivity — يستضيف منصة المعلمين.
            - windowSoftInputMode=adjustResize لضمان ظهور حقول الإدخال فوق لوحة المفاتيح.
        -->
        <activity
            android:name=".TeacherActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!--
            StudentActivity — يستضيف منصة الطلاب وأولياء الأمور.
        -->
        <activity
            android:name=".StudentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden" />

    </application>

</manifest>